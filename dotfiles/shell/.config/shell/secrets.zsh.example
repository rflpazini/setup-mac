# secrets.zsh.example — TEMPLATE.
#
# Copy to ~/.config/shell/secrets.zsh and fill in real values.
#   cp ~/.config/shell/secrets.zsh.example ~/.config/shell/secrets.zsh
#
# ~/.config/shell/secrets.zsh is gitignored and sourced automatically by .zshrc
# if it exists. NEVER put real secrets in any tracked file.

# GitHub PAT for private module / package-registry access (used with GOPRIVATE).
# export GITHUB_REGISTRY_TOKEN="ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Secret for running integration tests locally.
# export STE_SECRET="xxxxxxxxxxxxxxxxxxxx"
